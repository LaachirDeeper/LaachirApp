package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}
package com.laachirdeeper.adapts;

import android.content.Context;
import android.util.Log;
import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.LinearLayout;

import androidx.appcompat.widget.AppCompatImageButton;
import androidx.appcompat.widget.AppCompatImageView;
import androidx.appcompat.widget.AppCompatTextView;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import com.laachirdeeper.CustomDialog;
import com.laachirdeeper.ExpanderView;
import com.laachirdeeper.GtHub;
import com.laachirdeeper.InternCheck;
import com.laachirdeeper.R;
import com.laachirdeeper.ToasterType;
import com.laachirdeeper.Utility;
import com.laachirdeeper.acs.TRAV;
import com.laachirdeeper.user.SheetMailManager;

import org.jetbrains.annotations.NotNull;

import java.util.ArrayList;

public class TravAda extends RecyclerView.Adapter<RecyclerView.ViewHolder> {

    private final ArrayList<TravDataMo> items;
    private final TRAV mActivity;
    private final LayoutInflater mInflater;
    private final ExpanderView expanderView;
    private final TravelCategory category;
    public CustomDialog travDialog;
    private final NestedListAdapter[] nestedAdapters;

    public TravAda(ArrayList<TravDataMo> data, TRAV activity, TravelCategory category) {
        this.items = data;
        this.mActivity = activity;
        this.mInflater = LayoutInflater.from(mActivity);
        this.expanderView = new ExpanderView();
        this.category = category;
        this.nestedAdapters = new NestedListAdapter[data.size()];
    }

    public void refreshFileStates() {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates();
                }
            }
        }
    }

    public void updateFileState(String fileName) {
        if (nestedAdapters != null) {
            for (NestedListAdapter adapter : nestedAdapters) {
                if (adapter != null) {
                    adapter.refreshFileStates(fileName);
                }
            }
        }
    }

    public void cleanupMail() {
        SheetMailManager.unregisterCallbacks();
    }

    @Override
    public int getItemCount() {
        return items.size();
    }

    @Override
    public void onBindViewHolder(@NotNull RecyclerView.ViewHolder holder, int position) {
        TravDataMo model = items.get(position);
        MessageViewHolder messageViewHolder = (MessageViewHolder) holder;

        messageViewHolder.imageIc.setImageResource(model.getRecyImageIcon());
        messageViewHolder.arrowIco.setImageResource(model.getRecyArrowImage());
        messageViewHolder.titleTx.setText(model.getRecyName());

        ArrayList<TravDataProvider.ListItem> childItems = getChildItems(position);
        messageViewHolder.quantityTx.setText(
                mActivity.getString(R.string.item_quantity_1, childItems.size())
        );

        setupNestedRecyclerView(messageViewHolder.nestedRecyclerView, position);
    }

    private ArrayList<TravDataProvider.ListItem> getChildItems(int position) {
        TravDataProvider.getInstance().populateChildItems(category, position, mActivity);
        return TravDataProvider.getInstance().getChildItems(category, position);
    }

    private void setupNestedRecyclerView(RecyclerView recyclerView, int position) {
        ArrayList<TravDataProvider.ListItem> listItems = getChildItems(position);

        recyclerView.setLayoutManager(new LinearLayoutManager(mActivity));
        recyclerView.setHasFixedSize(true);
        recyclerView.setNestedScrollingEnabled(false);
        NestedListAdapter nestedAdapter = new NestedListAdapter(listItems, mActivity, position, category, this);
        nestedAdapters[position] = nestedAdapter;
        recyclerView.setAdapter(nestedAdapter);
    }

    @Override
    public int getItemViewType(int position) {
        return super.getItemViewType(position);
    }

    @NotNull
    @Override
    public RecyclerView.ViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
        View rootView = mInflater.inflate(R.layout.trav_dsn, parent, false);
        return new MessageViewHolder(rootView, expanderView, category);
    }

    private static class MessageViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {

        private final AppCompatImageView imageIc;
        private final AppCompatImageView arrowIco;
        private final AppCompatTextView titleTx;
        private final AppCompatTextView quantityTx;
        public final LinearLayout headerLayout;
        private final LinearLayout expandableContent;
        private final RecyclerView nestedRecyclerView;
        private final boolean[] isExpanded = {false};
        private final ExpanderView expanderView;
        public final Context context;
        private final TravelCategory category;

        private MessageViewHolder(View itemView, ExpanderView expanderView, TravelCategory category) {
            super(itemView);
            this.expanderView = expanderView;
            this.context = itemView.getContext();
            this.category = category;

            imageIc = itemView.findViewById(R.id.trav_image);
            arrowIco = itemView.findViewById(R.id.trav_arrow_rotate);
            titleTx = itemView.findViewById(R.id.trav_tt);
            quantityTx = itemView.findViewById(R.id.trav_quantity);
            headerLayout = itemView.findViewById(R.id.trav_recy_click_expan);
            nestedRecyclerView = itemView.findViewById(R.id.trav_list_recy);
            expandableContent = (LinearLayout) nestedRecyclerView.getParent();

            expandableContent.setVisibility(View.GONE);
            headerLayout.setOnClickListener(this);
        }

        @Override
        public void onClick(View v) {
            int pos = getBindingAdapterPosition();

            if (isExpanded[0]) {
                expanderView.collapseView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 0f);
            } else {
                expanderView.expandView(expandableContent, null);
                Utility.rotateArrowIco(arrowIco, 180f);
            }
            isExpanded[0] = !isExpanded[0];

            String categoryName = getCategoryName();
            switch (pos) {
                case 0:
                    Log.e("TravAda", categoryName +"Item 1");
                    break;
                case 1:
                    Log.e("TravAda", categoryName +"Item 2");
                    break;
                default:
                    break;
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }
    }

    private class NestedListAdapter extends RecyclerView.Adapter<NestedListAdapter.NestedViewHolder> {

        private final ArrayList<TravDataProvider.ListItem> items;
        public final Context mContext;
        private final int parentPosition;
        private final TravelCategory category;
        private final ArrayList<NestedViewHolder> viewHolders = new ArrayList<>();
        private final TravAda parentAdapter;

        public NestedListAdapter(ArrayList<TravDataProvider.ListItem> items, Context mContext,
                                 int parentPosition, TravelCategory category, TravAda parentAdapter) {
            this.items = items;
            this.mContext = mContext;
            this.parentPosition = parentPosition;
            this.category = category;
            this.parentAdapter = parentAdapter;
        }

        public void refreshFileStates() {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null && holder.currentItem.hasTrackInfo()) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        public void refreshFileStates(String fileName) {
            for (NestedViewHolder holder : viewHolders) {
                if (holder != null && holder.currentItem != null &&
                        holder.currentItem.hasTrackInfo() &&
                        fileName.equals(holder.currentItem.getFileName())) {
                    updateOpenButtonState(holder, holder.currentItem);
                }
            }
        }

        @Override
        public int getItemCount() {
            return items.size();
        }

        @Override
        public void onBindViewHolder(@NotNull NestedViewHolder holder, int position) {
            TravDataProvider.ListItem item = items.get(position);
            holder.bind(item);

            if (item.isShowImage()) {
                holder.graphImg.setVisibility(View.VISIBLE);
            } else {
                holder.graphImg.setVisibility(View.GONE);
            }

            if ((parentPosition == 0 && position == 0) ||
                    (parentPosition == 2 && position == 0)
            ) {
                // holder.circleIco.setVisibility(View.VISIBLE);

                holder.itemLayout.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    switch (parentPosition) {
                        case 0:
                            Log.e("TravAda", "long click on item 1");
                            break;
                        case 2:
                            Log.e("TravAda", "long click on item 3");
                            break;
                        default:
                            Log.e("TravAda", categoryName+"long click on item "+ (parentPosition + 1));
                    }
                    return true;
                });
            } else {
                holder.circleIco.setVisibility(View.GONE);
                holder.itemLayout.setOnLongClickListener(null);
            }
        }

        private String getCategoryName() {
            switch (category) {
                case EUROPE:
                    return "Europe";
                case AFRICA:
                    return "Africa";
                case ASIA:
                    return "Asia";
                default:
                    return "";
            }
        }

        @NotNull
        @Override
        public NestedViewHolder onCreateViewHolder(@NotNull ViewGroup parent, int viewType) {
            View itemView = LayoutInflater.from(parent.getContext())
                    .inflate(R.layout.trav_dsn_sub, parent, false);
            NestedViewHolder holder = new NestedViewHolder(itemView, category);
            viewHolders.add(holder);
            return holder;
        }

        private void updateOpenButtonState(NestedViewHolder holder, TravDataProvider.ListItem item) {
            if (item.hasTrackInfo()) {
                boolean fileExists = GtHub.checkFileExists(item.getFileName());
                Utility.setAlphaAndEnability(holder.openTrackBtn, fileExists);
            } else {
                Utility.setAlphaAndEnability(holder.openTrackBtn, false);
            }
        }

        class NestedViewHolder extends RecyclerView.ViewHolder implements View.OnClickListener {
            private final AppCompatTextView titleView;
            private final AppCompatTextView subtitleView;
            private final AppCompatImageView graphImg;
            private final AppCompatImageButton downlTrackBtn;
            private final AppCompatImageButton openTrackBtn;
            private final View circleIco;
            private final LinearLayout itemLayout;
            private final Context context;
            private final TravelCategory category;
            private TravDataProvider.ListItem currentItem;

            public NestedViewHolder(View itemView, TravelCategory category) {
                super(itemView);
                this.category = category;
                titleView = itemView.findViewById(R.id.trav_child_tt);
                subtitleView = itemView.findViewById(R.id.trav_child_tt_sub);
                graphImg = itemView.findViewById(R.id.trav_child_graphic_img);
                downlTrackBtn = itemView.findViewById(R.id.trav_child_ico_download);
                openTrackBtn = itemView.findViewById(R.id.trav_child_ico_open);
                circleIco = itemView.findViewById(R.id.trav_child_circle_ico);
                itemLayout = itemView.findViewById(R.id.trav_child_on_click);
                context = itemView.getContext();

                itemLayout.setOnClickListener(this);
                downlTrackBtn.setOnClickListener(this::onDownloadButtonClick);
                openTrackBtn.setOnClickListener(this::onOpenButtonClick);

                downlTrackBtn.setOnLongClickListener(this::onDownloadButtonLongClick);
                openTrackBtn.setOnLongClickListener(this::onOpenButtonLongClick);

                circleIco.setVisibility(View.GONE);
                Utility.setAlphaAndEnability(openTrackBtn, false);
            }

            private void onDownloadButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!checkInternetConnection()) {
                    return;
                }

                CustomDialog trackDialog = trackGetStatusDialog(context);

                GtHub.downloadFile(
                        context,
                        currentItem.getRepoOwner(),
                        currentItem.getRepoName(),
                        currentItem.getBranch(),
                        currentItem.getFilePath(),
                        currentItem.getFileName(),
                        trackDialog,
                        parentAdapter
                );
            }

            private void onOpenButtonClick(View v) {
                if (!currentItem.hasTrackInfo()) {
                    ToasterType.showNormal(context, context.getString(R.string.no_track_info));
                    return;
                }

                if (!GtHub.checkFileExists(currentItem.getFileName())) {
                    String expectedPath = GtHub.getExpectedFilePath(currentItem.getFilePath(), currentItem.getFileName());
                    ToasterType.showNormal(context, context.getString(R.string.file_not_exist_path, expectedPath));
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                    return;
                }

                GtHub.openFile(context, currentItem.getFileName());
            }

            private boolean onDownloadButtonLongClick(View v) {
                Log.e("TravAda", "Download btn long click");
                return true;
            }

            private boolean onOpenButtonLongClick(View v) {
                Log.e("TravAda", "Open btn long click");
                return true;
            }

            public void bind(TravDataProvider.ListItem item) {
                this.currentItem = item;
                titleView.setText(item.getTitle());
                Utility.setHtmlText(subtitleView, item.getSubtitle());
                graphImg.setImageResource(item.getImageGraphic());
                downlTrackBtn.setImageResource(item.getBtnDownload());
                openTrackBtn.setImageResource(item.getBtnOpen());

                if (item.hasTrackInfo()) {
                    boolean fileExists = GtHub.checkFileExists(item.getFileName());
                    Utility.setAlphaAndEnability(openTrackBtn, fileExists);
                } else {
                    Utility.setAlphaAndEnability(openTrackBtn, false);
                }

                /*titleView.setOnLongClickListener(v -> {
                    String categoryName = getCategoryName();
                    Utility.setClipboard(context, "Copied from " + categoryName + ":\n" + item.getTitle());
                    return true;
                });*/
            }

            private String getCategoryName() {
                switch (category) {
                    case EUROPE:
                        return "Europe";
                    case AFRICA:
                        return "Africa";
                    case ASIA:
                        return "Asia";
                    default:
                        return "";
                }
            }

            @Override
            public void onClick(View v) {
                int position = getBindingAdapterPosition();
                if (position != RecyclerView.NO_POSITION && context instanceof TRAV) {
                    Log.e("TravAda", "OnDismissListener click" + currentItem.getUrl());
                    //LinkConfirmDialog.show((TRAV) context, currentItem.getUrl());
                }
            }
        }
    }

    private boolean checkInternetConnection() {
        InternCheck internCheck = InternCheck.getInstance(mActivity);
        internCheck.forceRefreshState();
        if (internCheck.isAirplaneEnabled()) {
            ToasterType.showNormal(mActivity, "Airplane mode enabled!");
            return false;
        } else if (!internCheck.isInternetEnabled()) {
            ToasterType.showNormal(mActivity, "Internet disabled!");
            return false;
        } else if (internCheck.isUnknownState()) {
            ToasterType.showNormal(mActivity, "Failed to connect. Unknown state!");
            return false;
        }
        return true;
    }

    private CustomDialog trackGetStatusDialog(Context mtx) {
        if (travDialog != null && travDialog.isShowing()) {
            return travDialog;
        }

        travDialog = new CustomDialog(mtx, R.layout.track_get_status);

        travDialog.setCancelable(false);

        travDialog.setOnDismissListener(dialog -> {
            Log.e("TravAda", "OnDismissListener click");
        });

        View cancelButton = travDialog.findViewById(R.id.file_progss_posi);
        cancelButton.setOnClickListener(v -> {
            Log.e("TravAda", "Cancel button clicked");
            try {
                GtHub.cancelDownload(mtx);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            } catch (Exception e) {
                Log.e("TravAda", "Error canceling download: " + e.getMessage());

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }
            }
        });

        cancelButton.setOnLongClickListener(v -> {
            Log.i("TravAda", "Long click on cancel button - hiding dialog to continue in background");
            try {
                GtHub.setDialogHidden(true);

                if (travDialog != null && travDialog.isShowing()) {
                    travDialog.dismiss();
                }

                ToasterType.showNormal(mtx, mtx.getString(R.string.download_continues_background));

            } catch (Exception e) {
                Log.e("TravAda", "Error hiding dialog: " + e.getMessage());
            }
            return true;
        });

        travDialog.setStandardCorners(R.id.file_progss_corners);
        travDialog.show(R.style.dialogShow, 26);

        return travDialog;
    }
}

