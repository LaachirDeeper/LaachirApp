<?xml version="1.0" encoding="UTF-8"?>
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}

public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}

public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}

public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}

public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
public class GtHub {
    private static final String BASE_URL = "https://raw.githubusercontent.com";
    private static Timer progressTimer;
    public static DownloadManager downloadManager;
    private static long downloadId = -1;
    private static Future<?> downloadFuture;
    private static final ExecutorService executor = Executors.newSingleThreadExecutor();
    private static boolean isDownloadCancelled = false;
    private static boolean isDownloadPaused = false;
    private static boolean isDialogHidden = false;
    private static long currentDownloadProgress = 0;
    private static int fileLength = 0;
    private static File tempFile = null;
    private static String currentFileUrl = null;
    private static Timer timeoutTimer;
    private static long downloadStartTime = 0;
    private static final long DOWNLOAD_TIMEOUT = 120000; // 2 minutes timeout

    public static String currentRepoOwner = null;
    public static String currentRepoName = null;
    public static String currentBranch = null;
    public static String currentFilePath = null;
    private static String currentFileName = null;
    private static WeakReference<CustomDialog> progressDialogRef = null;
    private static WeakReference<TravAda> adapterRef = null;
    private static WeakReference<Context> contextRef = null;
    private static WeakReference<NotificationManager> notificationManagerRef = null;
    private static File currentDestFile = null;

    private static ConnectivityReceiver connectivityReceiver;

    private static final int STATUS_IDLE = 0;
    private static final int STATUS_DOWNLOADING = 1;
    private static final int STATUS_COMPLETED = 2;
    private static final int STATUS_FAILED = 3;
    private static final int STATUS_PAUSED = 4;
    public static int currentStatus = STATUS_IDLE;

    public static final int NOTIFICATION_ID = 1001;

    public static class ConnectivityReceiver extends BroadcastReceiver {
        @Override
        public void onReceive(Context context, Intent intent) {
            if (ConnectivityManager.CONNECTIVITY_ACTION.equals(intent.getAction())) {
                boolean noConnectivity = intent.getBooleanExtra(
                        ConnectivityManager.EXTRA_NO_CONNECTIVITY, false);

                if (noConnectivity) {
                    ToasterType.showNormal(context, "Connexion lost! Process paused.", Toast.LENGTH_LONG);
                    if (currentStatus == STATUS_DOWNLOADING) {
                        pauseDownload(context);
                    }
                } else {
                    if (currentStatus == STATUS_PAUSED) {
                        resumeDownload(context);
                    }
                }
            }
        }
    }

    private static void registerNetworkReceiver(Context context) {
        if (connectivityReceiver == null) {
            connectivityReceiver = new ConnectivityReceiver();
            IntentFilter filter = new IntentFilter(ConnectivityManager.CONNECTIVITY_ACTION);
            context.getApplicationContext().registerReceiver(connectivityReceiver, filter);
        }
    }

    private static void unregisterNetworkReceiver(Context context) {
        if (connectivityReceiver != null && context != null) {
            try {
                context.getApplicationContext().unregisterReceiver(connectivityReceiver);
            } catch (Exception e) {
                Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
            }
            connectivityReceiver = null;
        }
    }

    private static void pauseDownload(Context context) {
        if (currentStatus != STATUS_DOWNLOADING) {
            return;
        }

        Log.i("GtHub", "Pausing download due to network disconnection");
        isDownloadPaused = true;
        currentStatus = STATUS_PAUSED;

        updatePausedUI(context);

        if (downloadFuture != null && !downloadFuture.isDone()) {
            downloadFuture.cancel(true);
        }
        
        cancelTimeoutTimer();
    }

    private static void resumeDownload(Context context) {
        if (currentStatus != STATUS_PAUSED) {
            return;
        }

        Log.i("GtHub", "Resuming download after network reconnection");
        isDownloadPaused = false;
        currentStatus = STATUS_DOWNLOADING;

        updateResumingUI(context);

        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }

    private static void updatePausedUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_paused, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder pausedBuilder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.download_paused))
                        .setSmallIcon(android.R.drawable.stat_sys_warning)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    pausedBuilder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, pausedBuilder.build());
            }
        });
    }

    private static void updateResumingUI(Context context) {
        Handler handler = new Handler(Looper.getMainLooper());
        handler.post(() -> {
            CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
            if (progressDialog != null && progressDialog.isShowing()) {
                try {
                    AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);

                    if (percentText != null) {
                        int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                        String message = context.getString(R.string.downloading_resuming, progress);
                        percentText.setText(message);
                    }
                } catch (Exception ignored) {}
            }

            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
            if (notificationManager != null) {
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_progress, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                if (isDialogHidden) {
                    Intent intent = new Intent(context, TRAV.class);
                    intent.setAction("SHOW_DOWNLOAD_DIALOG");
                    intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                    PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                            PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                    builder.setContentIntent(pendingIntent)
                            .setAutoCancel(false);
                }

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        });
    }

    public static void downloadFile(Context context, String repoOwner, String repoName, String branch, String filePath,
                                   String fileName, CustomDialog progressDialog, TravAda adapter) {
        // If download is already in progress for the same file, just show the dialog with current progress
        if (currentStatus != STATUS_IDLE && fileName.equals(currentFileName)) {
            isDialogHidden = false;
            progressDialogRef = new WeakReference<>(progressDialog);
            
            // Update dialog with current progress
            if (progressDialog != null) {
                if (!progressDialog.isShowing()) {
                    progressDialog.show();
                }
                
                progressDialog.setCancelable(false);
                
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);
                
                int progress = fileLength > 0 ? (int) (currentDownloadProgress * 100 / fileLength) : 0;
                
                if (percentText != null) {
                    if (currentStatus == STATUS_PAUSED) {
                        percentText.setText(context.getString(R.string.downloading_paused, progress));
                    } else {
                        percentText.setText(context.getString(R.string.downloading_percent, progress));
                    }
                }
                
                if (progressBar != null) {
                    progressBar.setIndeterminate(false);
                    progressBar.setMax(100);
                    progressBar.setProgress(progress);
                }
            }
            return;
        }
        
        // Cancel any existing download before starting a new one
        if (downloadId != -1) {
            cancelDownload(context);
        }

        currentRepoOwner = repoOwner;
        currentRepoName = repoName;
        currentBranch = branch;
        currentFilePath = filePath;
        currentFileName = fileName;
        progressDialogRef = new WeakReference<>(progressDialog);
        adapterRef = new WeakReference<>(adapter);
        contextRef = new WeakReference<>(context);

        currentStatus = STATUS_DOWNLOADING;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        currentDownloadProgress = 0;
        downloadStartTime = System.currentTimeMillis();

        registerNetworkReceiver(context);

        currentFileUrl = String.format("%s/%s/%s/%s/%s", BASE_URL, repoOwner, repoName, branch, filePath);
        currentDestFile = getDestinationFile(filePath, fileName);

        // Create temporary file with unique name to prevent conflicts
        tempFile = new File(currentDestFile.getParentFile(), currentFileName + "." + System.currentTimeMillis() + ".tmp");
        if (tempFile.exists()) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temporary file: " + tempFile.getAbsolutePath());
            }
        }

        File parentDir = currentDestFile.getParentFile();
        if (parentDir != null && !parentDir.exists()) {
            if (!parentDir.mkdirs()) {
                Log.w("GtHub", "Failed to create parent directories: " + parentDir.getAbsolutePath());
            }
        }

        if (progressDialog != null) {
            if (!progressDialog.isShowing()) {
                progressDialog.show();
            }
            progressDialog.setCancelable(false);
        }

        AppCompatTextView percentText = null;
        LinearProgressIndicator progressBar = null;

        if (progressDialog != null) {
            percentText = progressDialog.findViewById(R.id.file_progss_percent);
            progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

            if (percentText != null) {
                percentText.setText(context.getString(R.string.downloading_percent, 0));
            }

            if (progressBar != null) {
                progressBar.setIndeterminate(false);
                progressBar.setMax(100);
                progressBar.setProgress(0);
            }
        }

        NotificationManager notificationManager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        notificationManagerRef = new WeakReference<>(notificationManager);

        NotificationCompat.Builder notificationBuilder = createNotificationBuilder(context, fileName);
        notificationManager.notify(NOTIFICATION_ID, notificationBuilder.build());
        
        startTimeoutTimer(context);
        downloadFileWithResume(context);
    }
    
    private static void startTimeoutTimer(Context context) {
        cancelTimeoutTimer();
        
        timeoutTimer = new Timer();
        timeoutTimer.schedule(new TimerTask() {
            @Override
            public void run() {
                if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0 && 
                    System.currentTimeMillis() - downloadStartTime > DOWNLOAD_TIMEOUT) {
                    
                    new Handler(Looper.getMainLooper()).post(() -> {
                        if (currentStatus == STATUS_DOWNLOADING && currentDownloadProgress == 0) {
                            ToasterType.showNormal(context, "Download timed out after 2 minutes with no progress", Toast.LENGTH_LONG);
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                new Handler(Looper.getMainLooper()), "Connection timed out", currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                        }
                    });
                }
            }
        }, DOWNLOAD_TIMEOUT, DOWNLOAD_TIMEOUT);
    }
    
    private static void cancelTimeoutTimer() {
        if (timeoutTimer != null) {
            timeoutTimer.cancel();
            timeoutTimer = null;
        }
    }

    private static void downloadFileWithResume(Context context) {
        final Handler handler = new Handler(Looper.getMainLooper());

        downloadFuture = executor.submit(() -> {
            try {
                URL url = new URL(currentFileUrl);
                HttpURLConnection connection = (HttpURLConnection) url.openConnection();

                if (currentDownloadProgress > 0) {
                    connection.setRequestProperty("Range", "bytes=" + currentDownloadProgress + "-");
                    Log.i("GtHub", "Resuming download from byte: " + currentDownloadProgress);
                }

                connection.connect();

                int responseCode = connection.getResponseCode();
                if (responseCode != HttpURLConnection.HTTP_OK && responseCode != HttpURLConnection.HTTP_PARTIAL) {
                    String errorMessage = context.getString(R.string.server_http_error,
                            connection.getResponseCode(), connection.getResponseMessage());
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, errorMessage, currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                    return;
                }

                if (fileLength == 0) {
                    fileLength = connection.getContentLength();
                    if (fileLength <= 0) {
                        Log.w("GtHub", "Unable to determine file size for download");
                    }
                }

                try (InputStream input = new BufferedInputStream(connection.getInputStream());
                     OutputStream output = new FileOutputStream(tempFile, currentDownloadProgress > 0)) {

                    byte[] data = new byte[4096];
                    long total = currentDownloadProgress;
                    int count;

                    long lastUpdateTime = System.currentTimeMillis();
                    final long UPDATE_INTERVAL = 250;

                    while ((count = input.read(data)) != -1) {
                        if (isDownloadCancelled) {
                            return;
                        }

                        if (isDownloadPaused) {
                            currentDownloadProgress = total;
                            return;
                        }

                        total += count;
                        currentDownloadProgress = total;

                        if (fileLength > 0) {
                            final int progress = (int) (total * 100 / fileLength);
                            long currentTime = System.currentTimeMillis();

                            if (currentTime - lastUpdateTime > UPDATE_INTERVAL || progress >= 100) {
                                lastUpdateTime = currentTime;
                                final long finalTotal = total;

                                handler.post(() -> {
                                    updateProgressUI(context, finalTotal);
                                });
                            }
                        }

                        output.write(data, 0, count);
                    }
                    output.flush();
                    
                    // Successfully downloaded file, now copy it to destination
                    copyTempFileToDestination(context, handler);
                }
            } catch (Exception e) {
                if (e instanceof IOException && !checkInternetConnection(context)) {
                    pauseDownload(context);
                } else {
                    Log.e("GtHub", "Download error: " + e.getMessage());
                    if (isDownloadCancelled) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, true);
                    } else {
                        pauseDownload(context);
                    }
                }
            }
        });
    }

    private static void copyTempFileToDestination(Context context, Handler handler) {
        if (tempFile == null || !tempFile.exists() || isDownloadCancelled) {
            return;
        }
        
        try {
            // Only delete the destination file now that we have a complete download
            if (currentDestFile.exists()) {
                if (!currentDestFile.delete()) {
                    Log.w("GtHub", "Failed to delete existing file: " + currentDestFile.getAbsolutePath());
                }
            }
            
            if (tempFile.renameTo(currentDestFile)) {
                handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                        handler, null, currentFileName,
                        notificationManagerRef != null ? notificationManagerRef.get() : null,
                        adapterRef != null ? adapterRef.get() : null, false);
            } else {
                if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.O) {
                    try (InputStream in = Files.newInputStream(tempFile.toPath());
                         OutputStream out = createOutputStream(currentDestFile)) {
                        byte[] buf = new byte[4096];
                        int len;
                        while ((len = in.read(buf)) > 0) {
                            out.write(buf, 0, len);
                        }
                        out.flush();
                        
                        // Keep the temp file until we confirm the destination file exists
                        if (currentDestFile.exists() && currentDestFile.length() > 0) {
                            if (!tempFile.delete()) {
                                Log.w("GtHub", "Failed to delete temporary file after copy: " + tempFile.getAbsolutePath());
                            }
                            
                            handleDownloadResult(true, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, null, currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        } else {
                            // If the destination file doesn't exist or is empty, there was a problem
                            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                    handler, "Failed to save file to destination", currentFileName,
                                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                                    adapterRef != null ? adapterRef.get() : null, false);
                        }
                    } catch (Exception e) {
                        handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                                handler, e.getMessage(), currentFileName,
                                notificationManagerRef != null ? notificationManagerRef.get() : null,
                                adapterRef != null ? adapterRef.get() : null, false);
                    }
                } else {
                    handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                            handler, "Failed to save file", currentFileName,
                            notificationManagerRef != null ? notificationManagerRef.get() : null,
                            adapterRef != null ? adapterRef.get() : null, false);
                }
            }
        } catch (Exception e) {
            Log.e("GtHub", "Error copying file: " + e.getMessage());
            handleDownloadResult(false, context, progressDialogRef != null ? progressDialogRef.get() : null,
                    handler, e.getMessage(), currentFileName, 
                    notificationManagerRef != null ? notificationManagerRef.get() : null,
                    adapterRef != null ? adapterRef.get() : null, false);
        }
    }

    private static boolean checkInternetConnection(Context context) {
        try {
            InternCheck internCheck = InternCheck.getInstance(context);
            internCheck.forceRefreshState();

            if (internCheck.isAirplaneEnabled()) {
                return false;
            } else if (!internCheck.isInternetEnabled()) {
                return false;
            } else if (internCheck.isUnknownState()) {
                return false;
            }
            return true;
        } catch (Exception e) {
            Log.e("GtHub", "Error checking internet connection: " + e.getMessage());
            return false;
        }
    }

    private static void updateProgressUI(Context context, long downloadedBytes) {
        CustomDialog progressDialog = progressDialogRef != null ? progressDialogRef.get() : null;
        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (downloadedBytes * 100 / fileLength);
                }

                if (percentText != null) {
                    percentText.setText(context.getString(R.string.downloading_percent, progress));
                }

                if (progressBar != null) {
                    progressBar.setProgress(progress);
                }
            } catch (Exception ignored) {}
        }

        NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;
        if (notificationManager != null) {
            int progress = 0;
            if (fileLength > 0) {
                progress = (int) (downloadedBytes * 100 / fileLength);
            }

            NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                    .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                    .setContentText(context.getString(R.string.downloading_progress, progress))
                    .setSmallIcon(android.R.drawable.stat_sys_download)
                    .setProgress(100, progress, false)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(true);

            if (isDialogHidden) {
                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);
            }

            notificationManager.notify(NOTIFICATION_ID, builder.build());
        }
    }

    private static NotificationCompat.Builder createNotificationBuilder(Context context, String fileName) {
        String channelId = "download_channel";

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    channelId,
                    context.getString(R.string.download_channel_name),
                    NotificationManager.IMPORTANCE_LOW);

            NotificationManager notificationManager =
                    (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
            notificationManager.createNotificationChannel(channel);
        }

        return new NotificationCompat.Builder(context, channelId)
                .setSmallIcon(android.R.drawable.stat_sys_download)
                .setContentTitle(context.getString(R.string.downloading_file, fileName))
                .setContentText(context.getString(R.string.download_in_progress))
                .setProgress(100, 0, false)
                .setPriority(NotificationCompat.PRIORITY_LOW)
                .setOngoing(true);
    }

    private static void finalizeNotification(boolean success, NotificationManager manager,
                                             Context context, String fileName, boolean isCancelled) {
        if (manager == null && context != null) {
            manager = (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);
        }

        if (manager == null) {
            Log.e("GtHub", "Cannot finalize notification: NotificationManager is null");
            return;
        }

        String channelId = "download_channel";

        if (success) {
            NotificationCompat.Builder completedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(context.getString(R.string.download_complete))
                    .setSmallIcon(android.R.drawable.stat_sys_download_done)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            completedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, completedBuilder.build());
        } else {
            NotificationCompat.Builder failedBuilder = new NotificationCompat.Builder(context, channelId)
                    .setContentTitle(context.getString(R.string.downloading_file, fileName))
                    .setContentText(isCancelled || isDownloadCancelled ?
                            context.getString(R.string.download_cancelled) :
                            context.getString(R.string.download_failed))
                    .setSmallIcon(isCancelled || isDownloadCancelled ?
                            android.R.drawable.stat_notify_sdcard :
                            android.R.drawable.stat_notify_error)
                    .setPriority(NotificationCompat.PRIORITY_LOW)
                    .setOngoing(false)
                    .setAutoCancel(true);

            failedBuilder.setProgress(0, 0, false);

            manager.cancel(NOTIFICATION_ID);
            manager.notify(NOTIFICATION_ID, failedBuilder.build());
        }
    }

    private static OutputStream createOutputStream(File file) throws IOException {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            return Files.newOutputStream(file.toPath());
        } else {
            return new FileOutputStream(file);
        }
    }

    public static String getExpectedFilePath(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);
        String fullPath;

        if (!dynamicPath.isEmpty()) {
            fullPath = baseDir.getAbsolutePath() + File.separator + dynamicPath + File.separator + fileName;
        } else {
            fullPath = baseDir.getAbsolutePath() + File.separator + fileName;
        }

        return fullPath;
    }

    public static String getActualFilePath(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null ? file.getAbsolutePath() : null;
    }

    private static File getDestinationFile(String filePath, String fileName) {
        File baseDir = getAppFolderDirectory();
        String dynamicPath = getDynamicPathFromGitHub(filePath);

        if (!dynamicPath.isEmpty()) {
            File fullPath = new File(baseDir, dynamicPath);
            if (!fullPath.exists()) {
                if (!fullPath.mkdirs()) {
                    Log.w("GtHub", "Failed to create directory structure: " + fullPath.getAbsolutePath());
                }
            }
            return new File(fullPath, fileName);
        } else {
            return new File(baseDir, fileName);
        }
    }

    private static String getDynamicPathFromGitHub(String filePath) {
        int lastSlashIndex = filePath.lastIndexOf('/');
        return lastSlashIndex > 0 ? filePath.substring(0, lastSlashIndex) : "";
    }

    private static File getAppFolderDirectory() {
        File docsDir = Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOCUMENTS);
        File appFolder = new File(docsDir, FileManagerUtil.APP_FOLDER);
        if (!appFolder.exists()) {
            if (!appFolder.mkdirs()) {
                Log.w("GtHub", "Failed to create app folder directory: " + appFolder.getAbsolutePath());
            }
        }
        return appFolder;
    }

    public static void cancelDownload(Context context) {
        if (context == null) {
            Log.e("GtHub", "Cannot cancel download: Context is null");
            return;
        }

        isDownloadCancelled = true;
        isDownloadPaused = false;

        if (downloadFuture != null && !downloadFuture.isDone()) {
            try {
                downloadFuture.cancel(true);
            } catch (Exception e) {
                Log.e("GtHub", "Error canceling download future: " + e.getMessage());
            }
        }

        if (downloadManager != null && downloadId != -1) {
            try {
                downloadManager.remove(downloadId);
            } catch (Exception ignored) {}
            downloadId = -1;
        }

        cancelProgressTracking();
        cancelTimeoutTimer();
        currentStatus = STATUS_IDLE;

        if (tempFile != null && tempFile.exists()) {
            try {
                if (!tempFile.delete()) {
                    Log.w("GtHub", "Failed to delete temp file on cancel: " + tempFile.getAbsolutePath());
                }
            } catch (Exception e) {
                Log.e("GtHub", "Error deleting temp file: " + e.getMessage());
            }
        }

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        try {
            NotificationManager notificationManager = notificationManagerRef != null ?
                    notificationManagerRef.get() : (NotificationManager) context.getSystemService(Context.NOTIFICATION_SERVICE);

            if (notificationManager != null) {
                finalizeNotification(false, notificationManager, context, currentFileName != null ? currentFileName : "", true);

                new Handler(Looper.getMainLooper()).postDelayed(() -> {
                    notificationManager.cancel(NOTIFICATION_ID);
                }, 1500);
            }

            ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
        } catch (Exception e) {
            Log.e("GtHub", "Error showing cancellation notification: " + e.getMessage());
        }

        resetDownloadSession();
    }

    public static void setDialogHidden(boolean hidden) {
        isDialogHidden = hidden;

        if (hidden) {
            Context context = contextRef != null ? contextRef.get() : null;
            NotificationManager notificationManager = notificationManagerRef != null ? notificationManagerRef.get() : null;

            if (context != null && notificationManager != null) {
                int progress = 0;
                if (fileLength > 0) {
                    progress = (int) (currentDownloadProgress * 100 / fileLength);
                }

                NotificationCompat.Builder builder = new NotificationCompat.Builder(context, "download_channel")
                        .setContentTitle(context.getString(R.string.downloading_file, currentFileName))
                        .setContentText(context.getString(R.string.downloading_background, progress))
                        .setSmallIcon(android.R.drawable.stat_sys_download)
                        .setProgress(100, progress, false)
                        .setPriority(NotificationCompat.PRIORITY_LOW)
                        .setOngoing(true);

                Intent intent = new Intent(context, TRAV.class);
                intent.setAction("SHOW_DOWNLOAD_DIALOG");
                intent.setFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP | Intent.FLAG_ACTIVITY_SINGLE_TOP);
                PendingIntent pendingIntent = PendingIntent.getActivity(context, 0, intent,
                        PendingIntent.FLAG_UPDATE_CURRENT | PendingIntent.FLAG_IMMUTABLE);

                builder.setContentIntent(pendingIntent)
                        .setAutoCancel(false);

                notificationManager.notify(NOTIFICATION_ID, builder.build());
            }
        }
    }

    /**
     * Reset all download session variables
     */
    private static void resetDownloadSession() {
        currentRepoOwner = null;
        currentRepoName = null;
        currentBranch = null;
        currentFilePath = null;
        currentFileName = null;
        progressDialogRef = null;
        adapterRef = null;
        contextRef = null;
        notificationManagerRef = null;
        currentDestFile = null;
        currentFileUrl = null;
        tempFile = null;
        fileLength = 0;
        currentDownloadProgress = 0;
        isDownloadPaused = false;
        isDownloadCancelled = false;
        isDialogHidden = false;
        downloadStartTime = 0;
    }

    private static void handleDownloadResult(boolean success, Context context, CustomDialog progressDialog,
                                             Handler handler, String errorMessage, String fileName,
                                             NotificationManager notificationManager, TravAda adapter,
                                             boolean wasCancelled) {
        cancelTimeoutTimer();
        currentStatus = success ? STATUS_COMPLETED : STATUS_FAILED;

        try {
            unregisterNetworkReceiver(context);
        } catch (Exception e) {
            Log.e("GtHub", "Error unregistering network receiver: " + e.getMessage());
        }

        if (progressDialog != null && progressDialog.isShowing()) {
            try {
                progressDialog.setCancelable(true);

                AppCompatTextView percentText = progressDialog.findViewById(R.id.file_progss_percent);
                LinearProgressIndicator progressBar = progressDialog.findViewById(R.id.file_progss_percent_bar);

                if (success) {
                    if (percentText != null) {
                        percentText.setText(context.getString(R.string.downloading_percent, 100));
                    }
                    if (progressBar != null) {
                        progressBar.setProgress(100);
                    }

                    finalizeNotification(true, notificationManager, context, fileName, wasCancelled);

                    new Handler().postDelayed(() -> {
                        try {
                            if (progressDialog.isShowing()) {
                                progressDialog.dismiss();
                            }
                        } catch (Exception ignored) {}
                    }, 500);
                } else {
                    if (percentText != null) {
                        if (isDownloadCancelled || wasCancelled) {
                            percentText.setText(context.getString(R.string.download_cancelled));
                        } else {
                            String displayMessage = context.getString(R.string.downloading_failed,
                                    (errorMessage != null ? errorMessage : context.getString(R.string.unknown_error)));
                            percentText.setText(displayMessage);
                        }
                    }

                    finalizeNotification(false, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
                }
            } catch (Exception ignored) {}
        } else {
            finalizeNotification(success, notificationManager, context, fileName, wasCancelled || isDownloadCancelled);
        }

        if (tempFile != null && tempFile.exists() && success) {
            if (!tempFile.delete()) {
                Log.w("GtHub", "Failed to delete temp file: " + tempFile.getAbsolutePath());
            }
        }

        isDialogHidden = false;

        if (success) {
            ToasterType.showNormal(context, context.getString(R.string.download_completed));
            if (adapter != null) {
                adapter.updateFileState(fileName);
            }
        } else {
            if (isDownloadCancelled || wasCancelled) {
                ToasterType.showNormal(context, context.getString(R.string.download_cancelled));
            } else {
                ToasterType.showError(context, context.getString(R.string.download_failed));
            }
        }
        
        resetDownloadSession();
    }

    private static void cancelProgressTracking() {
        if (progressTimer != null) {
            try {
                progressTimer.cancel();
                progressTimer.purge();
            } catch (Exception ignored) {}
            progressTimer = null;
        }
    }

    public static Uri getFileUri(Context context, String fileName) {
        File file = findFileInDocuments(fileName);
        if (file != null && file.exists()) {
            return FileProvider.getUriForFile(context, context.getPackageName() + Stringer.FILE_PROVIDER_AUTHORITY, file);
        }
        return null;
    }

    private static File findFileInDocuments(String fileName) {
        File baseDir = getAppFolderDirectory();
        File directFile = new File(baseDir, fileName);
        if (directFile.exists()) {
            return directFile;
        }
        return searchFileRecursively(baseDir, fileName);
    }

    private static File searchFileRecursively(File directory, String fileName) {
        File[] files = directory.listFiles();
        if (files != null) {
            for (File file : files) {
                if (file.isDirectory()) {
                    File found = searchFileRecursively(file, fileName);
                    if (found != null) {
                        return found;
                    }
                } else if (file.getName().equals(fileName)) {
                    return file;
                }
            }
        }
        return null;
    }

    public static boolean checkFileExists(String fileName) {
        File file = findFileInDocuments(fileName);
        return file != null && file.exists() && file.length() > 0;
    }

    public static void openFile(Context context, String fileName) {
        if (!checkFileExists(fileName)) {
            ToasterType.showNormal(context, context.getString(R.string.file_not_exist));
            return;
        }

        Uri fileUri = getFileUri(context, fileName);
        if (fileUri == null) {
            ToasterType.showError(context, context.getString(R.string.file_access_error));
            return;
        }

        String mimeType = getMimeType(fileName);

        Intent intent = new Intent(Intent.ACTION_VIEW);
        intent.setDataAndType(fileUri, mimeType);
        intent.addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION);

        try {
            context.startActivity(intent);
        } catch (ActivityNotFoundException e) {
            ToasterType.showError(context, context.getString(R.string.no_app_to_open_file));
        }
    }

    private static String getMimeType(String fileName) {
        String extension = MimeTypeMap.getFileExtensionFromUrl(fileName);
        if (extension != null) {
            String mimeType = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension.toLowerCase());
            if (mimeType != null) {
                return mimeType;
            }
        }

        if (fileName.endsWith(".kml")) {
            return "application/vnd.google-earth.kml+xml";
        } else if (fileName.endsWith(".gpx")) {
            return "application/gpx+xml";
        } else if (fileName.endsWith(".kmz")) {
            return "application/vnd.google-earth.kmz";
        }

        return "*/*";
    }

    public static void invalidateFileCache() {
        // File cache was removed
    }
}
